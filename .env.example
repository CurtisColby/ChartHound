# ChartHound — Environment Variables Reference
# Copy this to .env for local development (not needed for Docker; use docker-compose.yml)

# REQUIRED — Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_RANDOM_KEY

# Registration Lock (Constitution §4)
# Default: false (Lockdown Mode active)
# Set to true ONLY when adding a new user. Remove afterward.
CH_OPEN_REGISTRATION=false

# Database path (inside container)
DATABASE_URL=/data/charthound.db

# Path Translation
# Maps Plex/Emby file paths to Docker /music volume
MEDIA_SERVER_MUSIC_PREFIX=/media/nas/MUSIC
DOCKER_MUSIC_PREFIX=/music
